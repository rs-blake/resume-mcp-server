# ResumeUp Credentials
RESUMEUP_EMAIL=your-email@example.com
RESUMEUP_PASSWORD=your-password

# Session Configuration
RESUMEUP_SESSION_DIR=~/.resumeup_automation
RESUMEUP_HEADLESS=false

# MCP Server Configuration
MCP_TIMEOUT=120
MCP_PORT=8000

# LinkedIn Credentials (optional — manual login supported)
LINKEDIN_EMAIL=your-email@example.com
LINKEDIN_PASSWORD=your-password
LINKEDIN_SESSION_DIR=~/.linkedin_automation
LINKEDIN_HEADLESS=false
LINKEDIN_TIMEOUT=120

# Job search & application queue
APPLICATIONS_OUTPUT_DIR=~/applications
APPLICATION_STORE_PATH=~/.resumeup_automation/applications.json
PROFILE_SKILLS=AWS,Python,Kubernetes,Docker,Security
APPLICATION_PROFILE_PATH=examples/application_profile.json

# Pipeline tuning (section 2 defaults)
DEFAULT_MIN_MATCH_SCORE=0.35
DEFAULT_SEARCH_LIMIT=5
DAILY_TAILOR_CAP=10
MAX_CUSTOM_QUESTIONS=5
USE_LLM_SCREENING=true

# Optional LLM screening fallback (OpenAI-compatible)
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini

# Profile overrides (optional — prefer application_profile.json)
PROFILE_EMAIL=
PROFILE_PHONE=
PROFILE_SALARY_EXPECTATION=150000
PROFILE_WORK_AUTHORIZATION=Yes
PROFILE_REQUIRES_SPONSORSHIP=No
PROFILE_YEARS_EXPERIENCE=5
